{% extends '@!EasyAdmin/page/content.html.twig' %}
{% form_theme form '@EasyAdmin/crud/form_theme.html.twig' %}

{% block content_title %}
    <h1 class="title">Parse Recipe from Images</h1>
{% endblock %}

{% block main %}
    <p class="help-block">Upload one or more photos of the recipe (e.g. a card, book page, or screenshot). The AI will extract ingredients and steps in the background.</p>
    {{ form_start(form, { attr: { enctype: 'multipart/form-data' } }) }}
    {{ form_widget(form) }}
    {{ form_end(form) }}
{% endblock %}
