{% extends 'base.html.twig' %}

{% block title %}Shopping List{% endblock %}

{% block body %}
    <div class="container bg-dark">
        <h1 class="text-center text-light">Shopping List</h1>

        {% if items is empty %}
            <div class="text-center text-light mt-4">
                <p>Shopping list is empty.</p>
                <a href="{{ path('home') }}" class="btn btn-primary">Back to Recipes</a>
            </div>
        {% else %}
            <div class="d-flex gap-2 mb-4">
                <a href="{{ path('home') }}" class="btn btn-secondary">Back to Recipes</a>
                <form method="post" action="{{ path('shopping_list_clear') }}">
                    <button type="submit" class="btn btn-warning">Clear List</button>
                </form>
            </div>

            <details class="mb-4">
                <summary class="btn btn-outline-light d-inline-block mb-2">Ingredients Summary</summary>
                <div class="bg-light p-3 rounded">
                    <pre id="ingredientsSummaryText" class="mb-2">{% for ingredient in consolidated %}{{ ingredient.display ? ingredient.display ~ ' ' : '' }}{{ ingredient.name }}
{% endfor %}</pre>
                    <button type="button" class="btn btn-sm btn-primary" onclick="navigator.clipboard.writeText(document.getElementById('ingredientsSummaryText').innerText).then(function(){ this.textContent='Copied!'; }.bind(this))">Copy to Clipboard</button>
                </div>
            </details>

            <div class="row row-cols-1 row-cols-md-3 g-4">
                {% for item in items %}
                    <div class="col h-100">
                        <div class="card">
                            {% if item.recipe.image %}
                                <img src="{{ item.recipe.image starts with 'https' ? item.recipe.image : (item.recipe.image|aws_url) }}" class="card-img-top" alt="{{ item.recipe.name }}">
                            {% endif %}
                            <div class="card-body bg-light">
                                <h5 class="card-title">{{ item.recipe.name }}</h5>
                                <p class="card-text">{{ item.recipe.description }}</p>
                                <a href="{{ path('recipe_show', {'slug': item.recipe.slug}) }}" class="btn btn-primary">Show</a>
                                <form method="post" action="{{ path('shopping_list_remove', {'id': item.recipe.id}) }}" class="d-inline">
                                    <button type="submit" class="btn btn-danger">Remove</button>
                                </form>
                            </div>
                            <div class="card-footer">
                                <small class="text-muted">
                                    {% if item.recipe.mastered %}
                                        <i class="fa fa-check-circle mastered"></i>
                                    {% endif %}
                                    {% if item.recipe.mistakes | length > 0 %}
                                        {{ item.recipe.mistakes|length }} mistakes.
                                    {% endif %}
                                </small>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

{% endblock %}
