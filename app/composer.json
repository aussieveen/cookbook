{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-gd": "*",
        "doctrine/doctrine-bundle": "^2.18.2",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^3.6.3",
        "easycorp/easyadmin-bundle": "^4.29.5",
        "league/flysystem-aws-s3-v3": "^3.32.0",
        "league/flysystem-bundle": "^3.6.2",
        "nelmio/api-doc-bundle": "^5.10",
        "php-http/discovery": ">=1.20",
        "psr/http-factory-implementation": "*",
        "symfony/console": "^7.4.8",
        "symfony/doctrine-messenger": "^7.0",
        "symfony/dotenv": "^7.4.8",
        "symfony/flex": "^2.10.0",
        "symfony/framework-bundle": "^7.4.8",
        "symfony/http-client": "^7.4.8",
        "symfony/messenger": "^7.0",
        "symfony/runtime": "^7.4.8",
        "symfony/serializer": "^7.0",
        "symfony/webpack-encore-bundle": "^2.4",
        "symfony/yaml": "^7.4.8"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "mockery/mockery": "^1.6.12",
        "overtrue/phplint": "^9.7.1",
        "phpmd/phpmd": "^2.15.0",
        "phpunit/phpunit": "^12.5.16",
        "squizlabs/php_codesniffer": ">=4.0.1",
        "symfony/browser-kit": "^7.4.8",
        "symfony/css-selector": "^7.4.8",
        "symfony/maker-bundle": "^1.67",
        "symfony/var-dumper": "^7.4.8"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "run-tests": "composer run-phpcs && composer run-phpunit && composer run-phpmd && composer run-phplint",
        "run-phpcs": "vendor/bin/phpcs",
        "run-phpmd": "vendor/bin/phpmd src text phpmd-src.xml --exclude src/Migrations/ && vendor/bin/phpmd tests text phpmd-tests.xml",
        "run-phplint": "vendor/bin/phplint",
        "run-phpunit": "vendor/bin/phpunit",
        "run-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-filter src/ --coverage-html coverage"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^7.0"
        }
    }
}
